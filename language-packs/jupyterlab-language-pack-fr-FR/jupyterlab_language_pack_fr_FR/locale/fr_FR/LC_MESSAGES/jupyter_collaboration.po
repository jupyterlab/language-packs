#: packages/docprovider/src/notebookCellExecutor.ts:58
msgid "Kernel Terminating"
msgstr "Arrêt du noyau d'exécution"

#: packages/docprovider/src/notebookCellExecutor.ts:59
msgid "The kernel for %1 appears to be terminating. You can not run any cell for now."
msgstr "Le noyau d'exécution pour %1 est en cours d'arrêt. Vous ne pouvez pas exécuter de cellule pour le moment."

#: packages/docprovider/src/notebookCellExecutor.ts:69
msgid "Cell not executed due to pending input"
msgstr "La cellule n'a pas été exécutée en raison d'une entrée en attente"

#: packages/docprovider/src/notebookCellExecutor.ts:70
msgid "The cell has not been executed to avoid kernel deadlock as there is another pending input! Submit your pending input and try again."
msgstr "La cellule n'a pas été exécutée pour éviter de bloquer le noyau d'exécution car une autre entrée est en attente. Soumettez une valeur et réessayez."

